ANTHROPIC_API_KEY=your_anthropic_api_key_here
FRED_API_KEY=your_fred_api_key_here

# Tiger Brokers Open API (optional — needed for live account data & order placement)
TIGER_ID=your_tiger_developer_id
TIGER_ACCOUNT=your_account_number
TIGER_PRIVATE_KEY_PATH=C:/path/to/tiger_private_key.pem
TIGER_TRADE_MODE=paper

# Kotak Neo (optional — Indian market NSE/BSE; TOTP + MPIN entered in-app at login)
KOTAK_CONSUMER_KEY=your_kotak_consumer_key
KOTAK_MOBILE=+9198XXXXXXXX
KOTAK_UCC=your_unique_client_code
KOTAK_ENV=PROD

# App login gate (set via scripts/set_password.py). DEMO_ONLY=true disables live everywhere.
LIVE_UNLOCK_HASH=
DEMO_ONLY=
